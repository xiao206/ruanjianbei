<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.trae.monoservice.mapper.UserMapper">
    
    <select id="findByUsername" parameterType="string" resultType="com.trae.monoservice.entity.User">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>
    
    <select id="findById" parameterType="long" resultType="com.trae.monoservice.entity.User">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>
</mapper>